{
  "name": "digital-map-site",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "data:sync-companies": "tsx scripts/sync-companies-json.ts",
    "data:export-companies": "tsx scripts/export-companies-from-xlsx.ts",
