    "data:validate-companies:min100": "node scripts/validateCompaniesJson.mjs src/data/digital/companies.json --min-count=100",
    "data:drift-check": "tsx scripts/check-public-export-drift.ts"
  },
  "dependencies": {
    "astro": "^4.16.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^22.10.2",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.15.0",
    "eslint-plugin-astro": "^1.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5"
  }
