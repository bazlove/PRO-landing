---
/**
 * Yandex Metrica + Microsoft Clarity (production only by default).
 * Render once per document — included from `DigitalSeoLayout.astro` for `/digital`.
 */
const YANDEX_METRICA_ID = 109083928;
const CLARITY_PROJECT_ID = "wmvyikertt";

const isAnalyticsEnabled =
  import.meta.env.PROD && import.meta.env.PUBLIC_ENABLE_ANALYTICS !== "false";

function buildYandexMetrikaInline(counterId: number): string {
  return (
    '(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};' +
    "m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return}}" +
    "k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)" +
    '})(window,document,"script","https://mc.yandex.ru/metrika/tag.js","ym");\n' +
    `ym(${counterId},"init",{clickmap:true,trackLinks:true,accurateTrackBounce:true,webvisor:true});`
  );
}

function buildClarityInline(projectId: string): string {
  return (
    "(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};" +
    't=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;' +
    "y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)" +
    `})(window,document,"clarity","script","${projectId}");`
  );
}

const yandexInline = isAnalyticsEnabled ? buildYandexMetrikaInline(YANDEX_METRICA_ID) : "";
const clarityInline = isAnalyticsEnabled ? buildClarityInline(CLARITY_PROJECT_ID) : "";
---

{
  isAnalyticsEnabled && (
    <>
      <script is:inline set:html={yandexInline} />
      <noscript>
        <div>
          <img
            src={`https://mc.yandex.ru/watch/${YANDEX_METRICA_ID}`}
            style="position:absolute;left:-9999px;"
            alt=""
            width="1"
            height="1"
          />
        </div>
      </noscript>
      <script is:inline set:html={clarityInline} />
    </>
  )
}
