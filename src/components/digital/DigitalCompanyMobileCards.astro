---
import type { CompanyPublic } from "../../types/digital";
import {
  DIGITAL_BADGE_MAX_VISIBLE_MOBILE,
  formatRatingValueForUi,
  formatVacanciesRangeCopy,
  getCompanyBadges,
  getHiringFreshnessDisplay,
  getMobileCardPrimaryMeta,
  getMobileCardSecondaryMeta,
  getMobileCardStatusDisplay,
  getMobileCardStatusSignals,
} from "../../lib/digital/display";
import type { DrawerSummaryChip } from "../../lib/digital/display";
import DigitalCompanyBadges from "./DigitalCompanyBadges.astro";
import DigitalCompanyName from "./DigitalCompanyName.astro";
import DigitalCatalogLoadMore from "./DigitalCatalogLoadMore.astro";
import DigitalCompanyDetailTrigger from "./DigitalCompanyDetailTrigger.astro";
import { getCatalogItemDataAttrs } from "../../lib/digital/catalogItemAttrs";
import {
  getCatalogLimitConfig,
  isCatalogItemInitiallyHidden,
} from "../../lib/digital/displayLimits";

interface Props {
  companies: CompanyPublic[];
}

const { companies } = Astro.props;
const { initial: mobileInitialVisible } = getCatalogLimitConfig("mobile");

function formatRatings(company: CompanyPublic) {
  return `HeadHunter ${formatRatingValueForUi(company.hhRatingDisplay)} · Habr Career ${formatRatingValueForUi(company.habrRatingDisplay)}`;
}

function formatRatingsShort(company: CompanyPublic) {
  return `HH ${formatRatingValueForUi(company.hhRatingDisplay)} · Habr ${formatRatingValueForUi(company.habrRatingDisplay)}`;
}

function formatHiringFreshnessShort(company: CompanyPublic): {
  text: string;
  staleWarning: string | null;
  isMissing: boolean;
} {
  const hiring = getHiringFreshnessDisplay(company.hhVacanciesCheckedAt);

  return {
    text: hiring.hhLine
      .replace("Проверено на HH:", "HH проверен")
      .replace("Проверка HH:", "HH")
      .trim(),
    staleWarning: hiring.staleWarning,
    isMissing: hiring.isMissing,
  };
}
---

<div
  class="digital-mobile-cards"
  aria-label="База digital компаний (мобильная версия)"
  data-digital-catalog-surface="mobile"
>
  {
    companies.map((company, index) => {
      const hiring = getHiringFreshnessDisplay(company.hhVacanciesCheckedAt);
      const freshnessShort = formatHiringFreshnessShort(company);
      const tags = getCompanyBadges(company);
      const primaryMeta = getMobileCardPrimaryMeta(company);
      const secondaryMeta = getMobileCardSecondaryMeta(company);
      const statusDisplay = getMobileCardStatusDisplay(company);
      const visibleStatusSignals: DrawerSummaryChip[] = statusDisplay.visible;
      const hiddenStatusCount = statusDisplay.hiddenCount;
      const hiddenStatusSignals: DrawerSummaryChip[] = getMobileCardStatusSignals(company).slice(
        visibleStatusSignals.length,
      );
      const hiddenStatusSummary =
        hiddenStatusCount > 0
          ? `Ещё ${hiddenStatusCount}: ${hiddenStatusSignals
              .map((signal: DrawerSummaryChip) => signal.label)
              .join(", ")}`
          : "";
      const initiallyHidden = isCatalogItemInitiallyHidden(index, mobileInitialVisible);

      return (
        <article
          {...getCatalogItemDataAttrs(company)}
          class:list={[
            "digital-mobile-card",
            { "digital-catalog-item--hidden": initiallyHidden },
          ]}
        >
          <h3 class="digital-mobile-card__title">
            <DigitalCompanyName company={company} />
          </h3>
          {
            (primaryMeta || secondaryMeta) && (
              <div class="digital-mobile-card__meta">
                {primaryMeta && <p class="digital-mobile-card__meta-primary">{primaryMeta}</p>}
                {secondaryMeta && (
                  <p class="digital-mobile-card__meta-secondary">{secondaryMeta}</p>
                )}
              </div>
            )
          }

          <div class="digital-mobile-card__compact-phone">
            {
              (visibleStatusSignals.length > 0 || hiddenStatusCount > 0) && (
                <div class="digital-mobile-card__status-row digital-badges" aria-label="Статус">
                  {
                    visibleStatusSignals.map((signal: DrawerSummaryChip) => (
                      <span class:list={["digital-badge", signal.variantClass]}>
                        {signal.label}
                      </span>
                    ))
                  }
                  {
                    hiddenStatusCount > 0 && (
                      <span
                        class="digital-badge digital-badge--more"
                        aria-label={hiddenStatusSummary}
                        title={hiddenStatusSummary}
                      >
                        +{hiddenStatusCount}
                      </span>
                    )
                  }
                </div>
              )
            }
            <div class="digital-mobile-card__facts">
              <p class="digital-mobile-card__fact digital-mobile-card__fact--hiring">
                <span class="digital-mobile-card__fact--strong">
                  {formatVacanciesRangeCopy(company.vacanciesRange)}
                </span>
                {freshnessShort.text && (
                  <>
                    <span class="digital-mobile-card__fact-separator" aria-hidden="true">
                      ·
                    </span>
                    <span
                      class:list={[
                        "digital-mobile-card__fact-muted",
                        { "digital-muted": freshnessShort.isMissing },
                      ]}
                    >
                      {freshnessShort.text}
                    </span>
                  </>
                )}
                {freshnessShort.staleWarning && (
                  <span class="digital-stale-label"> · {freshnessShort.staleWarning}</span>
                )}
              </p>
              <p class="digital-mobile-card__fact">{formatRatingsShort(company)}</p>
            </div>
          </div>

          <div class="digital-mobile-card__details">
            <p class="digital-mobile-row">
              <span class="digital-mobile-row__label">Статус найма:</span> {company.hiringStatus} ·{" "}
              {formatVacanciesRangeCopy(company.vacanciesRange)}
            </p>
            <p class="digital-mobile-row digital-mobile-row--muted">
              {hiring.isMissing ? (
                <span class="digital-muted">{hiring.hhLine}</span>
              ) : (
                hiring.hhLine
              )}
              {hiring.staleWarning && (
                <span class="digital-stale-label"> · {hiring.staleWarning}</span>
              )}
            </p>
            <p class="digital-mobile-row">
              <span class="digital-mobile-row__label">Формат:</span> {company.workFormat} · Гео:{" "}
              {company.hiringGeo}
            </p>
            <p class="digital-mobile-row">
              <span class="digital-mobile-row__label">Рейтинги:</span> {formatRatings(company)}
            </p>
            {
              tags.length > 0 && (
                <p class="digital-mobile-row digital-mobile-row--tags">
                  <span class="digital-mobile-row__label">Теги:</span>
                </p>
              )
            }
            <DigitalCompanyBadges company={company} maxVisible={DIGITAL_BADGE_MAX_VISIBLE_MOBILE} />
          </div>

          <DigitalCompanyDetailTrigger
            companyId={company.id}
            class="digital-company-detail-trigger--mobile"
          />
        </article>
      );
    })
  }
  <DigitalCatalogLoadMore surface="mobile" total={companies.length} />
</div>
