---
import type { DigitalFilterOptions } from "../../lib/digital/filterOptions";
import {
  DIGITAL_DEFAULT_PAGE_SIZE,
  DIGITAL_PAGE_SIZE_OPTIONS,
} from "../../lib/digital/displayLimits";
import {
  DIGITAL_FILTER_PRESETS_PRIMARY,
  DIGITAL_FILTER_PRESETS_SECONDARY,
} from "../../lib/digital/filterPresets";
import { getTagColorClass } from "../../lib/digital/tagColors";

interface Props {
  options: DigitalFilterOptions;
}

const { options } = Astro.props;
const selectPlaceholder = "Все";
---

<div id="digital-catalog-filters" class="digital-catalog-filters" data-digital-catalog-filters>
  <noscript>
    <style is:inline>
      .digital-catalog-filters__advanced-toggle {
        display: none !important;
      }
      .digital-catalog-filters__advanced {
        display: block !important;
      }
    </style>
    <p class="digital-catalog-filters__noscript">
      Фильтры работают при включённом JavaScript. Полный список компаний доступен ниже.
    </p>
  </noscript>

  <div class="digital-catalog-filters__panel digital-card">
    <div class="digital-catalog-filters__row digital-catalog-filters__row--search">
      <div class="digital-catalog-filters__field digital-catalog-filters__field--search">
        <div class="digital-catalog-filters__header">
          <div class="digital-catalog-filters__header-copy">
            <h2 id="digital-catalog-heading" class="digital-catalog-filters__heading">
              Поиск работодателей
            </h2>
            <p class="digital-catalog-filters__subheading">
              По названию, городу, нише и формату работы
            </p>
          </div>
          <button
            type="button"
            class="digital-catalog-filters__clear digital-catalog-filters__clear--header"
            data-digital-filter-clear
            data-digital-filter-clear-tablet-header
            hidden
          >
            Сбросить
          </button>
        </div>
        <div class="digital-catalog-filters__search-wrap">
          <svg
            class="digital-catalog-filters__search-icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
            <path
              d="M20 20l-4-4"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
          <input
            id="digital-filter-search"
            class="digital-catalog-filters__input"
            type="search"
            name="q"
            placeholder="Компания, город или ниша"
            autocomplete="off"
            enterkeyhint="search"
            data-digital-filter-search
            data-digital-filter-search-default-placeholder="Компания, город или ниша"
            data-digital-filter-search-narrow-placeholder="Компания или ниша"
            aria-labelledby="digital-catalog-heading"
          />
        </div>
      </div>
      <div class="digital-catalog-filters__actions digital-catalog-filters__actions--search">
        <button type="button" class="digital-catalog-filters__clear" data-digital-filter-clear hidden>
          Сбросить
        </button>
      </div>
    </div>

    <section class="digital-catalog-filters__presets" aria-labelledby="digital-quick-filters-heading">
      <h3 id="digital-quick-filters-heading" class="digital-catalog-filters__presets-title">
        Быстрые фильтры
      </h3>
      <div class="digital-catalog-filters__presets-row">
        <div
          class="digital-presets digital-catalog-filters__presets--primary"
          role="toolbar"
          aria-label="Быстрые фильтры"
        >
          {
            DIGITAL_FILTER_PRESETS_PRIMARY.map((preset) => (
              <button
                type="button"
                class:list={["preset-chip", getTagColorClass(preset.id)]}
                data-digital-preset={preset.id}
                aria-pressed="false"
              >
                {preset.label}
              </button>
            ))
          }
          <button
            type="button"
            class="digital-catalog-filters__presets-more-toggle"
            data-digital-presets-more-toggle
            aria-expanded="false"
            aria-controls="digital-presets-secondary"
            aria-label="Показать дополнительные быстрые фильтры"
          >
            <span class="digital-catalog-filters__presets-more-icon" data-digital-presets-more-icon aria-hidden="true">+</span>
          </button>
        </div>
        <div
          id="digital-presets-secondary"
          class="digital-presets digital-catalog-filters__presets--secondary"
          role="toolbar"
          aria-label="Дополнительные быстрые фильтры"
          data-digital-presets-secondary
          hidden
        >
          {
            DIGITAL_FILTER_PRESETS_SECONDARY.map((preset) => (
              <button
                type="button"
                class:list={["preset-chip", getTagColorClass(preset.id)]}
                data-digital-preset={preset.id}
                aria-pressed="false"
              >
                {preset.label}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <p
      class="digital-catalog-filters__active-status digital-catalog-filters__active-status--mobile"
      data-digital-filter-active-status-mobile
      aria-live="polite"
      hidden
    ></p>

    <div class="digital-catalog-filters__toolbar">
      <button
        type="button"
        class="digital-catalog-filters__advanced-toggle"
        data-digital-filter-advanced-toggle
        aria-expanded="false"
        aria-controls="digital-filter-advanced"
      >
        <span data-digital-filter-advanced-toggle-label>Показать расширенные фильтры ↓</span>
      </button>

      <p
        class="digital-catalog-filters__active-status digital-catalog-filters__active-status--desktop"
        data-digital-filter-active-status-desktop
        aria-live="polite"
        hidden
      ></p>

      <label class="digital-catalog-filters__page-size" for="digital-page-size">
        <span class="digital-catalog-filters__page-size-label digital-catalog-filters__page-size-label--desktop">Показывать по</span>
        <span class="digital-catalog-filters__page-size-label digital-catalog-filters__page-size-label--mobile">Показывать:</span>
        <select
          id="digital-page-size"
          class="digital-catalog-filters__page-size-select"
          data-digital-page-size
          aria-label="Количество компаний на странице"
        >
          {
            DIGITAL_PAGE_SIZE_OPTIONS.map((size) => (
              <option value={size} selected={size === DIGITAL_DEFAULT_PAGE_SIZE}>
                {size}
              </option>
            ))
          }
        </select>
      </label>

      <button
        type="button"
        class="digital-catalog-filters__clear digital-catalog-filters__clear--utility"
        data-digital-filter-clear
        data-digital-filter-clear-utility
        hidden
      >
        Сбросить
      </button>
    </div>

    <div
      id="digital-filter-advanced"
      class="digital-catalog-filters__advanced"
      data-digital-filter-advanced
      hidden
    >
      <div class="digital-catalog-filters__grid">
        <div class="digital-catalog-filters__field">
          <label class="digital-catalog-filters__label" for="digital-filter-city">Город</label>
          <select id="digital-filter-city" class="digital-catalog-filters__select" data-digital-filter-city>
            <option value="">{selectPlaceholder}</option>
            {options.cities.map((city) => <option value={city}>{city}</option>)}
          </select>
        </div>

        <div class="digital-catalog-filters__field">
          <label class="digital-catalog-filters__label" for="digital-filter-type">Тип компании</label>
          <select id="digital-filter-type" class="digital-catalog-filters__select" data-digital-filter-type>
            <option value="">{selectPlaceholder}</option>
            {options.companyTypes.map((type) => <option value={type}>{type}</option>)}
          </select>
        </div>

        <div class="digital-catalog-filters__field">
          <label class="digital-catalog-filters__label" for="digital-filter-niche">Ниша</label>
          <select id="digital-filter-niche" class="digital-catalog-filters__select" data-digital-filter-niche>
            <option value="">{selectPlaceholder}</option>
            {options.niches.map((niche) => <option value={niche}>{niche}</option>)}
          </select>
        </div>

        <div class="digital-catalog-filters__field">
          <label class="digital-catalog-filters__label" for="digital-filter-hiring">Статус найма</label>
          <select
            id="digital-filter-hiring"
            class="digital-catalog-filters__select"
            data-digital-filter-hiring
          >
            <option value="">{selectPlaceholder}</option>
            {
              options.hiringStatuses.map((status) => (
                <option value={status}>{status}</option>
              ))
            }
          </select>
        </div>

        <div class="digital-catalog-filters__field">
          <label class="digital-catalog-filters__label" for="digital-filter-format">Формат работы</label>
          <select id="digital-filter-format" class="digital-catalog-filters__select" data-digital-filter-format>
            <option value="">{selectPlaceholder}</option>
            {
              options.workFormats.map((format) => (
                <option value={format}>{format}</option>
              ))
            }
          </select>
        </div>

        <div class="digital-catalog-filters__field">
          <label class="digital-catalog-filters__label" for="digital-filter-size">Размер компании</label>
          <select id="digital-filter-size" class="digital-catalog-filters__select" data-digital-filter-size>
            <option value="">Любой</option>
            {options.sizes.map((size) => <option value={size}>{size}</option>)}
          </select>
        </div>
      </div>
    </div>
  </div>

  <p
    class="digital-catalog-empty"
    data-digital-catalog-empty
    hidden
    role="status"
    aria-live="polite"
  >
    Ничего не найдено. Попробуйте изменить фильтры.
  </p>
</div>
