---
import SiteAnalytics from "../components/analytics/SiteAnalytics.astro";

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  webPageJsonLd: string;
}

const { title, description, canonicalUrl, webPageJsonLd } = Astro.props;

// TODO(release): switch /digital robots back to index,follow before production SEO launch.
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" id="digital-robots-meta" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline type="application/ld+json" set:html={webPageJsonLd} />
    <script is:inline>
      (function () {
        if (!location.search || location.search.length <= 1) return;
        var robots = document.getElementById("digital-robots-meta");
        if (robots) robots.setAttribute("content", "noindex,follow");
      })();
    </script>
    <SiteAnalytics />
  </head>
  <body class="digital-page">
    <slot />
  </body>
</html>
