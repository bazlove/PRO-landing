---
import SiteAnalytics from "../components/analytics/SiteAnalytics.astro";

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogImageUrl: string;
  ogImageAlt: string;
  webPageJsonLd: string;
}

const {
  title,
  description,
  canonicalUrl,
  ogImageUrl,
  ogImageAlt,
  webPageJsonLd,
} = Astro.props;

const hasQueryParams = Astro.url.search.length > 0;
const robotsContent = hasQueryParams ? "noindex,follow" : "index,follow";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} id="digital-robots-meta" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="pro.site.com" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <script is:inline type="application/ld+json" set:html={webPageJsonLd} />
    <SiteAnalytics />
  </head>
  <body class="digital-page">
    <slot />
  </body>
</html>
